{
    "name": "@jundayw/axios-signature",
    "version": "1.0.2",
    "description": "A lightweight Axios interceptor that automatically adds signature authentication (HMAC-SHA1/SHA256/SHA512, MD5, etc.) to outgoing requests. Protect your API with data integrity and anti‑tampering mechanisms.",
    "keywords": [
        "Axios",
        "Axios Request Interceptor",
        "Signature",
        "HMAC-SHA1",
        "HMAC-SHA256",
        "HMAC-SHA512",
        "MD5"
    ],
    "license": "MIT",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist",
        "LICENSE",
        "README.md"
    ],
    "scripts": {
        "build": "tsc",
        "prepublishOnly": "npm run build"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/jundayw/axios-signature.git"
    },
    "dependencies": {
        "axios": "^1.15.0",
        "crypto-js": "^4.2.0",
        "ts-pattern": "^5.9.0"
    },
    "devDependencies": {
        "@types/crypto-js": "^4.2.2",
        "typescript": "^6.0.2"
    },
    "author": {
        "name": "Mr.Moore",
        "email": "jundayw@gmail.com",
        "url": "https://github.com/jundayw"
    },
    "bugs": {
        "url": "https://github.com/jundayw/axios-signature/issues"
    },
    "homepage": "https://github.com/jundayw/axios-signature#readme"
}
