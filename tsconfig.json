{
    "compilerOptions": {
        /* 基础选项 */
        "target": "ES2020",
        // 输出的 JS 版本（Node.js 14+ 支持 ES2020）
        "module": "ESNext",
        // 模块系统：NodeNext 同时支持 ESM/CJS，也可选 "CommonJS" 或 "ESNext"
        "outDir": "./dist",
        // 编译输出目录
        "rootDir": "./src",
        // 源码根目录
        "removeComments": true,
        // 是否移除注释（建议保留声明注释）

        /* 类型声明生成 */
        "declaration": true,
        // 生成 .d.ts 文件
        "declarationMap": false,
        // 生成 .d.ts.map（支持跳转源码）
        "sourceMap": false,
        // 生成 .js.map（调试用）
        "emitDeclarationOnly": false,
        // 只生成 .d.ts（设为 true 则不输出 .js）
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "**/*.test.ts"
    ]
}
